local Players = game:GetService("Players")
local lp = Players.LocalPlayer

task.spawn(function()
    while true do
        -- Nhịp nghỉ giữa mỗi đợt nhảy ngẫu nhiên từ 5 đến 8 giây
        task.wait(math.random(5, 8)) 
        
        local char = lp.Character
        local hum = char and char:FindFirstChild("Humanoid")
        
        if hum and hum.Health > 0 then
            -- Mỗi đợt nhảy từ 1 đến 4 cái
            local jumpCount = math.random(1, 4)
            
            for i = 1, jumpCount do
                -- Ép trạng thái nhảy để chắc chắn hoạt động
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
                
                -- Đợi 0.2s để nhân vật kịp rời đất
                task.wait(0.2)
                
                -- Đợi chạm đất rồi mới nhảy cái tiếp (chống double jump)
                while hum.FloorMaterial == Enum.Material.Air do
                    task.wait()
                end
                
                -- Khoảng nghỉ ngắn giữa các cái nhảy trong cùng 1 đợt
                task.wait(math.random(3, 6) / 10)
            end
        end
    end
end)
