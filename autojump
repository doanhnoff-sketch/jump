local Players = game:GetService("Players")
local lp = Players.LocalPlayer

task.spawn(function()
    while true do
        -- Nhịp nghỉ ngẫu nhiên từ 5 đến 10 giây giữa mỗi đợt nhảy
        task.wait(math.random(5, 10)) 
        
        local char = lp.Character
        local hum = char and char:FindFirstChild("Humanoid")
        
        if hum and hum.Health > 0 then
            -- Mỗi đợt nhảy ngẫu nhiên từ 1 đến 4 cái
            local jumpCount = math.random(1, 4)
            
            for i = 1, jumpCount do
                -- Ép trạng thái nhảy (bypass các giới hạn của game)
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
                
                -- Đợi một chút để nhân vật thực sự rời khỏi mặt đất
                task.wait(0.2)
                
                -- Đợi cho đến khi chạm đất hoàn toàn (chống double jump)
                while hum.FloorMaterial == Enum.Material.Air do
                    task.wait()
                end
                
                -- Khoảng nghỉ ngắn giữa các cú nhảy (giống người thật bấm phím)
                task.wait(math.random(3, 6) / 10)
            end
        end
    end
end)
